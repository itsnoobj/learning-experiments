#!/bin/sh

# Verify assets can be generated (catches missing SVGs before CI fails)
if command -v rsvg-convert >/dev/null 2>&1 && command -v jq >/dev/null 2>&1; then
  echo "pre-push: running sync-assets.sh..."
  bash scripts/sync-assets.sh || exit 1
else
  echo "pre-push: skipping sync-assets (install librsvg + jq for local validation)"
fi

# Verify all available missions have complete assets (chapter, quiz, svg, audio)
echo "pre-push: checking mission completeness..."
node scripts/check-missions.mjs || exit 1

cd apps/web && npx vitest run
